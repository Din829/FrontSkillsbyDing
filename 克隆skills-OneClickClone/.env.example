# gen-refs.cjs 的 API key 配置范本
# 用法：复制成 .env（去掉 .example），填上你的 key。
# 或者干脆设成环境变量（env 优先级更高，不用这个文件）。
#
# gen-refs 找 key 的顺序：① 环境变量 → ② 当前工作目录/.env → ③ 脚本同目录/.env
# 换任何电脑：export 环境变量，或在跑命令的目录丢一个 .env，二选一即可。

# OpenAI（GPT-image-2，gen-refs 默认后端）— https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Gemini（Nano Banana，--backend gemini，真 16:9）— https://aistudio.google.com/apikey
GEMINI_API_KEY=
